# Example configuration for dtop
# Default location: ~/.config/dtop/dtop.conf (legacy: dtop.toml)

# How often collectors should refresh. Accepts Go duration strings (e.g. "1s",
# "500ms", "2m"). Per-plugin overrides are set with interval under each
# [plugins.config.<id>] section below.
update_interval = "2s"

# Reload config changes on the fly when this file changes.
live_reload = false

[theme]
# Theme name. "default" uses the built-in theme.
# Custom themes live at ~/.config/dtop/themes/<name>.toml
# <name> must match: [a-z0-9][a-z0-9_-]*
# See docs/theme-schema.md for the full theme schema.
name = "default"

[layout]
# Layout mode: "grid" (fixed multi-column), "flow" (auto columns), or "vertical" (single column stack).
mode = "grid"

# Number of columns in grid mode.
columns = 2

[plugins]
# Enable plugins by id.
enabled = ["clock", "cpu", "memory", "network", "process"]

# Per-plugin configuration is stored under plugins.config.<plugin_id>
[plugins.config]

[plugins.config.clock]
# No options yet.
# interval overrides update_interval for this plugin only. Accepts any Go
# duration string (e.g. "500ms", "1s", "5s"). The scheduler will not start a
# new collection while the previous one is still running (non-overlapping).
# interval = "1s"

[plugins.config.cpu]
# interval = "1s"  — override update_interval for this plugin (non-overlapping; see clock section).
# Show per-core utilization lines.
per_core = true

# Attempt to read CPU temperature (Linux).
show_temp = false

# Show average CPU frequency.
show_freq = true

# Show CPU package power draw via RAPL (Linux, requires permissions).
show_watts = false

[plugins.config.memory]
# interval = "2s"  — override update_interval for this plugin (non-overlapping; see clock section).
# Show swap usage.
show_swap = true

# Show disk capacity and usage.
show_disks = true

# Show disk I/O statistics (read/write rates).
show_io_stat = true

# Use base-10 sizes (KB, MB, GB) instead of base-1024 (KiB, MiB, GiB).
base_10_sizes = false

# Include ZFS ARC cache size (Linux only, if ZFS is present).
zfs_arc_cached = false

# Filter disks by mount point (optional). If empty, shows all physical filesystems.
# Example: disks_filter = ["/", "/home"]
# disks_filter = []

[plugins.config.network]
# interval = "1s"  — override update_interval for this plugin (non-overlapping; see clock section).
# Interface name to monitor (empty selects the first non-loopback interface).
interface = ""

# Show IPv6 addresses (if present).
show_ipv6 = true

[plugins.config.battery]
# No battery-specific options yet.
# interval = "5s"  — override update_interval for this plugin (non-overlapping; see clock section).

[plugins.config.process]
# interval = "2s"  — override update_interval for this plugin (non-overlapping; see clock section).
# Show process tree view with parent-child relationships.
tree_view = false

# Sort processes by: pid, name, cpu, mem, threads, user.
sort_by = "cpu"

# Filter processes by name or command (case-insensitive substring match).
# filter = "python"

# Maximum number of processes to display (0 = unlimited).
max_display = 20

# Follow a specific PID on startup (0 disables).
# follow_pid = 1234

# Use /proc/[pid]/smaps for detailed memory (slower).
use_smaps = false

# Optional preset slots (0-9). Load with: p then slot digit.
# Save current view into a slot with: P then slot digit.
# Delete a saved slot with: D then slot digit.
# Export a slot to <config-dir>/presets/preset-<slot>.toml with: E then slot digit.
# Import a slot from <config-dir>/presets/preset-<slot>.toml with: I then slot digit.
[presets.1]
layout_mode = "grid"
layout_columns = 2
update_interval = "2s"
visible_boxes = ["cpu", "memory", "network", "process"]

[presets.2]
layout_mode = "vertical"
update_interval = "1s"
visible_boxes = ["cpu", "process"]
